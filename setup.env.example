# setup.env.example — machine-readable answers for a promptless setup.mjs run.
#
# Usage:
#   cp setup.env.example setup.env      # setup.env is gitignored (holds your Clerk pk)
#   $EDITOR setup.env                   # fill in the values below
#   set -a; source setup.env; set +a    # export every SETUP_* var into the shell
#   node setup.mjs --yes                # parameterizes both Workers, no prompts
#
# setup.env.example is committed; setup.env is NOT (see .gitignore).
#
# These are EXACTLY the 11 env vars setup.mjs resolveInputs() reads. Leave any
# *_NAME / *_TITLE / *_BUCKET blank to derive it from SETUP_NAME (e.g. blank
# SETUP_D1_NAME → "<slug>-db"). See docs/deployment-intake.md for where each lands.
#
# NOTE: --theme and --custom-domain have NO env equivalent — pass them as flags:
#   node setup.mjs --yes --theme <tweakcn-url-or-path> --custom-domain app.example.com

# Group 1 — Identity (feeds setup.mjs)
# App display name → index.html <title>, sidebar wordmark
SETUP_APP_NAME="My Dashboard"
# Worker + package slug → wrangler.jsonc name, package.json name
SETUP_NAME=my-dashboard

# Group 4 — Clerk publishable key → wrangler.jsonc vars, .dev.vars, .env.local
# Leave blank to skip; accepts pk_test_… / pk_live_…
SETUP_CLERK_PK=

# Group 1 — Dashboard resources (blank → derived from SETUP_NAME)
# Dashboard D1 name → wrangler.jsonc database_name
SETUP_D1_NAME=my-dashboard-db
# Dashboard KV title → `wrangler kv namespace create` cmd
SETUP_KV_TITLE=my-dashboard-cache

# --- Optional CMS module (only needed if you deploy cms/) -------------------
# All CMS resource names are blank-derivable from SETUP_NAME; see docs/cms.md.
# CMS Worker name → cms/wrangler.jsonc name
SETUP_CMS_NAME=my-dashboard-cms
# CMS D1 name → cms/wrangler.jsonc database_name
SETUP_CMS_D1_NAME=my-dashboard-cms-db
# CMS R2 bucket → cms/wrangler.jsonc bucket_name
SETUP_CMS_R2_BUCKET=my-dashboard-cms-media
# CMS KV title → `wrangler kv namespace create` cmd
SETUP_CMS_KV_TITLE=my-dashboard-cms-cache
# CMS CORS origin (= exact dashboard origin) → cms/wrangler.jsonc vars.CORS_ORIGINS
# Blank at fork time — the *.workers.dev origin is unknown until first deploy.
SETUP_CMS_CORS_ORIGIN=
# CMS API URL (= CMS origin) → dashboard .env.local VITE_CMS_API_URL (+ derives BETTER_AUTH_URL)
# Blank at fork time — the *.workers.dev origin is unknown until first deploy.
SETUP_CMS_API_URL=
