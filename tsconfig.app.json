{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Alias */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/client/*"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  // worker-configuration.d.ts (wrangler types output) lives at the repo root, NOT under
  // src, so it must be listed explicitly for the generated `Env` global to resolve when
  // Plan 02/03 routes declare `new Hono<{ Bindings: Env }>()` (Pitfall 4).
  "include": ["src", "worker-configuration.d.ts"],
  // Worker tests import the virtual `cloudflare:test` module, which only resolves inside
  // the @cloudflare/vitest-pool-workers runtime (vitest runs them via esbuild, no tsc gate).
  // Excluding them keeps the SPA/app build (DOM libs) clean. Phase 6 adds a dedicated
  // worker-test tsconfig if CI needs to type-check tests.
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
